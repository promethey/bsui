    "bootstrap-icons": "^1.13.1",
    "css-loader": "^7.1.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.0.0",
    "jsdom": "^29.1.1",
    "mini-css-extract-plugin": "^2.10.0",
