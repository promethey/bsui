{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": "src",

    "jsx": "react-jsx",

    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",

    "checkJs": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "skipLibCheck": true,

    "paths": {
      "components/*": ["components/*"],
      "utils/*": ["utils/*"],
      "helpers/*": ["helpers/*"],
      "hooks/*": ["hooks/*"]
    }
  },

  "include": ["src", "tests", "storybook"],
  "exclude": ["node_modules", "dist"]
}
