{
  "compilerOptions": {
    "checkJs": false,
    "strict": false,

    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "paths": {
      "components/*": ["./src/components/*"],
      "utils/*": ["./src/utils/*"],
      "helpers/*": ["./src/helpers/*"],
      "constants/*": ["./src/constants/*"],
      "core/*": ["./src/core/*"]
    },

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
